# Copy this file to .env.local and fill in your values

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Convex
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=

# MongoDB
MONGODB_URI=

# Browser Use Cloud (v2 API: https://api.browser-use.com/api/v2)
BROWSER_USE_API_KEY=
# Optional: override base URL (default: https://api.browser-use.com/api/v2)
# BROWSER_USE_API_URL=https://api.browser-use.com/api/v2

# Supermemory
SUPERMEMORY_API_KEY=

# Daytona
DAYTONA_API_KEY=

# Laminar (observability — traces LLM calls; init in instrumentation.ts)
LAMINAR_API_KEY=
# Optional: for client-side tracing
# NEXT_PUBLIC_LAMINAR_API_KEY=

# HUD
HUD_API_KEY=
